<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<VBox alignment="CENTER" fillWidth="false" prefHeight="578.0" prefWidth="408.0" spacing="5.0" style="-fx-border-color: #444; -fx-padding: 15; -fx-border-width: 2;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="todo.ui.MainUIController">

    <Text strokeType="OUTSIDE" strokeWidth="0.0" styleClass="title-text" text="Todo List">
        <font>
            <Font name="Ebrima Bold" size="41.0" />
        </font>
    </Text>

    <TextField fx:id="searchField" promptText="Search tasks">
        <VBox.margin>
            <Insets />
        </VBox.margin>
    </TextField>
   <Button mnemonicParsing="false" onAction="#searchTask" text="Search" />

    <ListView fx:id="taskList" prefHeight="400.0" prefWidth="408.0" />

    <TextField fx:id="taskInput" promptText="Enter task" />

    <Button onAction="#addTask" text="Add" />
    <Button onAction="#editTask" text="Edit" />
    <Button onAction="#completeTask" text="Complete" />
    <Button onAction="#deleteTask" text="Delete" />
    <Button onAction="#toggleDarkMode" text="Dark Mode" />

</VBox>
